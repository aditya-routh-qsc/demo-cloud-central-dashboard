[sync]
interval_minutes = 60
cooldown_seconds = 1200

[database]
path = outputs/dashboard_cache.db

[dashboard]
# Comma-separated keywords. Team is shown if team name contains any keyword (case-insensitive).
# Example: team_visibility_keywords = reflect, devops, infra
team_visibility_keywords = reflect, infrastructure, subscription

# Optional comma-separated keywords for Team dropdown options in dashboard filters.
# Empty means show all teams in dropdown.
# Example: team_dropdown_keywords = reflect, devops, infra
team_dropdown_keywords = unmapped, reflect, subscription, infrastructure
